# Anthropic API key — powers the AI-generated movie pitches.
# Get one at https://console.anthropic.com/settings/keys
#
# Copy this file to .env.local and fill in your key:
#   cp .env.example .env.local
#
# Without a key (or if the AI call fails), the app automatically falls back to
# local pitch generation — it still works, just without the AI writing.
ANTHROPIC_API_KEY=your-api-key-here
